meta {
  name: 11 - Add Book L'Étranger (Admin Only)
  type: http
  seq: 11
}

post {
  url: http://localhost:3000/books/new
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt_token}}
}

body:json {
  {
    "title": "L'Étranger",
    "year": 1942,
    "editor": "Gallimard",
    "image": "https://example.com/letranger.jpg",
    "category": "roman",
    "author": 2
  }
}

settings {
  encodeUrl: true
  timeout: 0
}