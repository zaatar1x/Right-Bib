meta {
  name: 03 - Sign Up User
  type: http
  seq: 3
}

post {
  url: http://localhost:3000/auth/signup
  body: json
  auth: inherit
}

body:json {
  {
    "email": "user@example.com",
    "username": "user1",
    "password": "user123",
    "role": "user"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}